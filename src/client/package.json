{
  "name": "client",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "build": "NODE_TLS_REJECT_UNAUTHORIZED='0' remix build",
    "dev": "NODE_TLS_REJECT_UNAUTHORIZED='0' remix dev",
    "css-build": "node-sass --omit-source-map-url styles/styles.scss styles/styles.css",
    "css-watch": "yarn css-build --watch",
    "start": "remix-serve build"
  },
  "dependencies": {
    "@remix-run/node": "^1.7.0",
    "@remix-run/react": "^1.7.0",
    "@remix-run/serve": "^1.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^1.7.0",
    "@remix-run/eslint-config": "^1.7.0",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "bulma": "^0.9.4",
    "bulma-prefers-dark": "^0.1.0-beta.1",
    "eslint": "^8.20.0",
    "eslint-config-prettier": "^8.5.0",
    "node-sass": "^7.0.3",
    "prettier": "^2.7.1",
    "typescript": "^4.7.4"
  },
  "engines": {
    "node": ">=14"
  }
}
