{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "yarn build:cs && yarn build:css",
    "build:cs": "dotnet build",
    "build:css": "sass --no-source-map Styles/Styles.scss wwwroot/dist/styles.css",
    "dev": "dotnet watch",
    "dev:css": "sass --watch --no-source-map Styles/Styles.scss wwwroot/dist/styles.css",
    "format": "dotnet csharpier . && dotnet format",
    "restore": "dotnet restore"
  },
  "devDependencies": {
    "bulma": "^0.9.4",
    "bulma-prefers-dark": "^0.1.0-beta.1",
    "sass": "^1.55.0"
  }
}
