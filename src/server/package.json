{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@3.2.2",
  "scripts": {
    "dev": "dotnet watch",
    "build": "dotnet build",
    "build:js": "./esbuild.js",
    "restore": "dotnet restore",
    "lint": "dotnet csharpier . && dotnet format"
  },
  "eslintConfig": {
    "extends": "eslint:recommended",
    "env": {
      "browser": true,
      "commonjs": true,
      "es6": true
    },
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module",
      "ecmaFeatures": {
        "jsx": true
      }
    }
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tsconfig/create-react-app": "^1.0.2",
    "@tsconfig/node18": "^1.0.1",
    "esbuild": "^0.15.10",
    "eslint": "^8.20.0",
    "eslint-config-prettier": "^8.5.0",
    "prettier": "^2.7.1",
    "typescript": "^4.8.4"
  }
}
