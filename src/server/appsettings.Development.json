{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=funicular_db;Username=postgres;Password=postgres;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenIddictServerOptions": {
    "AuthorizationEndpointUris": ["/connect/authorize"],
    "DeviceEndpointUris": ["/connect/device"],
    "IntrospectionEndpointUris": ["/connect/introspection"],
    "LogoutEndpointUris": ["/connect/logout"],
    "TokenEndpointUris": ["/connect/token"],
    "UserinfoEndpointUris": ["/connect/userinfo"],
    "VerificationEndpointUris": ["/connect/verify"],
    "CodeChallengeMethods": ["S256"],
    "GrantTypes": [
      "authorization_code",
      "urn:ietf:params:oauth:grant-type:device_code",
      "password",
      "refresh_token"
    ],
    "ResponseModes": [
      "form_post",
      "fragment",
      "query",
      "code"
    ],
    "Scopes": [
      "email",
      "profile",
      "roles",
      "offline_access"
    ],
    "RequireProofKeyForCodeExchange": true
  },
  "OpenIddictServerAspNetCoreOptions": {
    "EnableStatusCodePagesIntegration": true,
    "EnableAuthorizationEndpointPassthrough": true,
    "EnableLogoutEndpointPassthrough": true,
    "EnableTokenEndpointPassthrough": true,
    "EnableUserinfoEndpointPassthrough": true,
    "EnableVerificationEndpointPassthrough": true
  }
}
