<!DOCTYPE html>
<html>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"] - Funicular</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons@@latest/iconfont/tabler-icons.min.css">
        <link rel="stylesheet" href="~/dist/styles.css" asp-append-version="true" />
    </head>
    <body>
        <nav class="navbar" role="navigation" aria-label="main navigation">
          <div class="navbar-brand">
              <a asp-controller="Home" asp-action="Index" class="navbar-item">Funicular.Server</a>
              <a role="button" class="navbar-burger" aria-label="menu" aria-expanded="false" data-target="navbarBasicExample">
                  <span aria-hidden="true"></span>
                  <span aria-hidden="true"></span>
                  <span aria-hidden="true"></span>
              </a>
          </div>

          <div id="navbarBasicExample" class="navbar-menu">
            <div class="navbar-start">
                <a asp-controller="Home" asp-action="Index" class="navbar-item">Home</a>
                <a asp-controller="Home" asp-action="About" class="navbar-item">About</a>
                <a asp-controller="Home" asp-action="Contact" class="navbar-item">Contact</a>
            </div>
            <div class="navbar-end">
                @await Html.PartialAsync("_LoginPartial")
            </div>
          </div>
        </nav>
        <div class="container">
            @RenderBody()
            <hr />
            <footer>
                <p>&copy; 2015 - Funicular.Server</p>
            </footer>
        </div>
        @RenderSection("scripts", required: false)
    </body>
</html>
