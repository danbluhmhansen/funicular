@page "/Characters"

@if (characters?.Any() == true)
{
  <table class="table">
    <thead>
      <tr>
        <th>Id</th>
        <th>Name</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var character in characters)
      {
        <tr>
          <td>@character.Id</td>
          <td>@character.Name</td>
        </tr>
      }
    </tbody>
  </table>
}