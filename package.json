{
  "name": "funicular",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.0.0-rc.22",
  "repository": {
    "type": "git",
    "url": "https://github.com/danbluhmhansen/funicular"
  },
  "author": {
    "name": "Dan Bluhm Hansen",
    "url": "https://github.com/danbluhmhansen"
  },
  "engines": {
    "node": "^14.13.1 || >=16.0.0",
    "yarn": ">=1.22.0",
    "npm": "please-use-yarn"
  },
  "workspaces": [
    "src/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -pt run build",
    "dev:server": "yarn workspace @funicular/server dev:cs",
    "dev:client": "yarn workspace @funicular/blazor dev",
    "restore": "yarn workspaces foreach run restore",
    "lint": "yarn workspaces foreach run lint",
    "efDatabaseUpdate": "dotnet ef database update \"$@\" --project src/server",
    "efDatabaseDrop": "dotnet ef database drop \"$@\" --project src/server",
    "efMigrationsAdd": "dotnet ef migrations add \"$@\" --project src/server",
    "efMigrationsRemove": "dotnet ef migrations remove \"$@\" --project src/server",
    "postinstall": "husky install"
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "extends": [
      "eslint:recommended",
      "prettier"
    ],
    "env": {
      "browser": true,
      "commonjs": true,
      "es6": true,
      "es2022": true
    },
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module",
      "ecmaFeatures": {
        "jsx": true
      }
    }
  },
  "eslintIgnore": [
    "globals.d.ts"
  ],
  "devDependencies": {
    "eslint": "^8.20.0",
    "eslint-config-prettier": "^8.5.0",
    "husky": "^8.0.1",
    "lint-staged": "^13.0.3",
    "prettier": "^2.7.1",
    "typescript": "^4.8.4"
  },
  "lint-staged": {
    "*.cs": [
      "dotnet csharpier",
      "dotnet format src/server --include"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
